<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us</title>

    <link rel="stylesheet" href="/style.css">

    <!-- FONT AWESOME -->
    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
</head>
<body>

<%- include("partials/navbar") %>

<!-- ================= ABOUT HERO ================= -->

<section class="about-hero">

    <div class="about-overlay">

        <h1>About Us</h1>

        <div class="about-line"></div>

    </div>

</section>

<!-- ================= ABOUT CONTAINER ================= -->

<section class="about-wrapper">

    <!-- LEFT -->
    <div class="about-left">

        <span class="about-badge">
            <i class="fa-solid fa-shield-halved"></i>
            Trusted Since 2006
        </span>

        <h2>
            Premium Agricultural Distribution Network Across Kutch
        </h2>

        <p>
            Welcome to <strong>UMIYA Agro Agencies</strong> —
            a trusted name in the agricultural industry dedicated
            to serving farmers and retailers with premium quality
            products and reliable services.
        </p>

        <p>
            Our main branch operates as a leading wholesaler and
            distributor of pesticides and fertilizers across the
            Kutch district with trusted agricultural solutions
            that improve farming productivity and crop quality.
        </p>

        <p>
            We also operate 5 retail branches in different locations
            for better accessibility and faster service.
            Retailers can directly purchase products from our
            branches or contact our main office for bulk orders.
        </p>

        <p>
            We are committed to delivering the best agricultural
            products with trusted service and long-term customer
            relationships.
        </p>

        <p>
            With a strong distribution network and experienced team,
            we ensure timely product availability and customer
            satisfaction across every branch.
        </p>

        <p class="experience-text">
            With <span>20+ years of experience</span> in the agro
            industry and partnerships with
            <span>50+ leading companies</span>,
            UMIYA Agro Agencies continues to grow as a reliable
            name in agricultural distribution and retail services.
        </p>

        <!-- STATS -->

        <div class="stats-row">

            <div class="stat-card">
                <i class="fa-solid fa-award"></i>
                <h3>20+</h3>
                <p>Years Experience</p>
            </div>

            <div class="stat-card">
                <i class="fa-solid fa-shop"></i>
                <h3>5</h3>
                <p>Retail Branches</p>
            </div>

            <div class="stat-card">
                <i class="fa-solid fa-users"></i>
                <h3>50+</h3>
                <p>Leading Companies</p>
            </div>

        </div>

    </div>

    <!-- RIGHT -->

    <div class="about-right">

        <!-- SERVICES -->

        <div class="about-box">

            <div class="box-title">
                <i class="fa-solid fa-seedling"></i>
                <h3>Our Services</h3>
            </div>

            <ul>
                <li>Wholesale Distribution</li>
                <li>Retail Agro Products</li>
                <li>Pesticides & Fertilizers Supply</li>
                <li>Bulk Orders for Retailers</li>
                <li>Farmer Product Guidance</li>
            </ul>

        </div>

        <!-- WHY CHOOSE -->

        <div class="about-box">

            <div class="box-title">
                <i class="fa-solid fa-medal"></i>
                <h3>Why Choose Us?</h3>
            </div>

            <ul>
                <li>Genuine Company Products</li>
                <li>Premium Quality Products</li>
                <li>Fast Product Availability</li>
                <li>Direct Retailer Purchase</li>
                <li>Strong Distribution Network</li>
                <li>Customer Support & Guidance</li>
            </ul>

        </div>

    </div>

</section>

<!-- ================= BOTTOM SECTION ================= -->

<section class="about-bottom">

    <div class="bottom-left">
        <i class="fa-solid fa-hand-holding-heart"></i>

        <p>
            UMIYA Agro Agencies believes in quality, trust,
            and continuous growth in the agriculture sector.
            <span>
                We proudly serve farmers, retailers, and business
                partners with dedication, honesty, and reliable
                agro solutions.
            </span>
        </p>
    </div>

    <div class="bottom-right">

        <i class="fa-solid fa-location-dot"></i>

        <p>
            Visit our branches or contact the main office
            to discuss your product requirements and business
            opportunities.
        </p>

    </div>

</section>

<!-- ================= OUR PARTNERS ================= -->

<section class="partners-section">

    <div class="partners-heading">

        <span>OUR PARTNERS</span>

        <h2>Meet Our Partners</h2>

        <p>
            Dedicated professionals working together to deliver
            the best agricultural solutions.
        </p>

    </div>

    <div class="partners-container">

        <!-- PARTNER 1 -->

        <div class="partner-card">

            <img src="/images/partner1.jpg" alt="Partner">

            <h3>Rahul Sharma</h3>

            <p>Co-Founder & CEO</p>

        </div>

        <!-- PARTNER 2 -->

        <div class="partner-card">

            <img src="/images/partner2.jpg" alt="Partner">

            <h3>Neha Verma</h3>

            <p>Co-Founder & COO</p>

        </div>

        <!-- PARTNER 3 -->

        <div class="partner-card">

            <img src="/images/partner3.jpg" alt="Partner">

            <h3>Amit Patel</h3>

            <p>Head of Sales</p>

        </div>

        <!-- PARTNER 4 -->

        <div class="partner-card">

            <img src="/images/partner4.jpg" alt="Partner">

            <h3>Pooja Singh</h3>

            <p>Marketing Head</p>

        </div>

    </div>

</section>

<%- include("partials/footer") %>

</body>
</html>