<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <!-- YEH LINE SABSE IMPORTANT HAI MOBILE RESPONSIVENESS KE LIYE -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>Umiya Agro Agencies</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
</head>
<body>

<!-- Navbar Partial included here -->
<%- include("partials/navbar") %>

<section class="hero">
    <div class="hero-content">
        <span>Premium Agricultural Excellence</span>
        <h1>Leading Wholesaler of Fertilizers & Pesticides</h1>
        <p>Innovative solutions, superior seeds, trusted fertilizers and next-gen farming technology.</p>

        <div class="hero-buttons">
            <button class="primary-btn">Explore Products</button>
            <button class="secondary-btn">Learn More</button>
        </div>
    </div>
</section>

<section class="products">
    <div class="card">
        <h2>Pesticides</h2>
        <p>Protect Crops with High-Quality Pesticides</p>
    </div>

    <div class="card">
        <h2>Premium Fertilizers</h2>
        <p>Advanced nutrition for stronger and healthier crops.</p>
    </div>

    <div class="card">
        <h2>Hybrid Seeds</h2>
        <p>High-performance seeds engineered for maximum productivity.</p>
    </div>
</section>

<div class="section-title">
    <h2>Main Branch Location</h2>
</div>

<section class="info-section">
    <div class="info-card">

        <!-- LEFT: MAP (Fixed the broken iframe tag) -->
        <div class="info-map">
            <iframe 
             src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d565.0453204682362!2d69.68966680338964!3d23.255508590748647!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3950e1f5821f4063%3A0x9b2fd95606bedae7!2z4KqJ4Kqu4Kq_4Kqv4Kq-IOCqj-Cql-CrjeCqsOCriyDgqo_gqpzgqqjgq43gqrjgq4A!5e0!3m2!1sen!2sin!4v1777903053169!5m2!1sen!2sin" 
             width="100%" 
             height="100%" 
             style="border:0;" 
             allowfullscreen="" 
             loading="lazy" 
             referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </div>

        <!-- RIGHT: TEXT -->
        <div class="info-content">
            <h2>Wholesale Distribution</h2>
            <p>
                Distributing pesticides & fertilizers across Kutch.
                Trusted wholesale supply for farmers and retailers.
            </p>
            <span class="since">Since 2006</span>
        </div>

    </div>
</section>

<div class="section-title">
    <h2>Multi - Brand  Products</h2>
</div>

<div class="slider">
    <div class="slide-track">
        <% companies.forEach(c => { %>
            <div class="slide">
                <div class="logo-box">
                <img src="<%= c.image %>" alt="Company Logo">
                </div>
            </div>
        <% }) %>

        <!-- duplicate for smooth loop -->
        <% companies.forEach(c => { %>
            <div class="slide">
                <div class="logo-box">
                <img src="<%= c.image.replace('/uploads/', '/images/uploads/') %>" alt="Company Logo">
                </div>
            </div>
        <% }) %>
    </div>
</div>

<%- include("partials/footer") %>

</body>
</html>